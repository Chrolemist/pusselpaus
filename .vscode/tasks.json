{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Frontend: dev",
      "type": "shell",
      "command": "npm",
      "args": ["run", "dev"],
      "isBackground": true,
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "options": {
        "cwd": "${workspaceFolder}/pusselpaus"
      }
    },
    {
      "label": "Frontend: build",
      "type": "shell",
      "command": "npm",
      "args": ["run", "build"],
      "group": "build",
      "options": {
        "cwd": "${workspaceFolder}/pusselpaus"
      }
    }
  ]
}
